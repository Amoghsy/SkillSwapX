# SkillSwap X — Backend Environment Variables
# Copy this to .env and fill in your values

APP_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=skillswapx
DB_USER=root
DB_PASS=your_mysql_password

# JWT
JWT_SECRET=replace_with_a_random_64_char_string
JWT_EXPIRY=900
JWT_REFRESH=604800
GEMINI_API_KEY=

# Social authentication
# Google uses Google Identity Services ID tokens. GitHub's web flow also
# requires a server-side secret; never expose GITHUB_CLIENT_SECRET in Vite.
GOOGLE_CLIENT_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:5173/login

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# AI Microservice
AI_SERVICE_URL=http://localhost:8000

# Rate Limiting
RATE_LIMIT=100
