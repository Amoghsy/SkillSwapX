# ai-service/.env — copy to .env and fill in

PHP_BACKEND_URL=http://localhost/api
# MySQL (same DB as PHP backend)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=skillswapx
DB_USER=root
DB_PASS=your_mysql_password

# Model settings
EMBEDDING_MODEL=all-MiniLM-L6-v2
SIMILARITY_THRESHOLD=0.35
MODERATION_THRESHOLD=0.75
GEMINI_API_KEY=